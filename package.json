    "resources": {
      "media": [
        {
          "menuIcon": true,
          "type": "png",
          "name": "IMAGE_MENU_ICON",
          "file": "icon.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_MUTE",
          "file": "img/mute.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_DISCONNECT",
          "file": "img/bt-disconnect.png",
          "memoryFormat": "1BitPalette"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_BT_CONNECT",
          "file": "img/bt.png",
          "memoryFormat": "1BitPalette"
