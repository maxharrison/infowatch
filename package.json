{
  "name": "max-infowatch",
  "author": "Max Harrison",
  "version": "11.0.0",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "suncalc": "^1.9.0"
  },
  "pebble": {
    "displayName": "InfoWatch",
