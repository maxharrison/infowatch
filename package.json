      "CLAY_SHOW_QT",
      "CLAY_SHOW_BT",
      "CLAY_SHOW_BT_DISCONNECT",
      "CLAY_VIBE",
      "CLAY_SHOW_AM_PM",
      "CLAY_COLOR_SATURDAY",
      "CLAY_COLOR_SUNDAY",
      "CLAY_COLOR_TIME",
      "CLAY_DAY_NIGHT_SHADING",
      "CLAY_SECOND_CITY_ENABLED",
